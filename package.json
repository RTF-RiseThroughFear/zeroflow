{
  "name": "zeroflow",
  "version": "0.1.0",
  "description": "Zero reflow. 120fps streaming. Drop-in React component for AI chat interfaces.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "cd demo && npm run dev",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": ["react","streaming","ai","chat","reflow","pretext","performance","llm","markdown","zero-reflow","120fps"],
  "author": "David Bisong <zido@disturbingcanada.com>",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/RTF-RiseThroughFear/zeroflow.git" },
  "homepage": "https://github.com/RTF-RiseThroughFear/zeroflow"
}